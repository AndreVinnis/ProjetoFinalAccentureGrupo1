node_modules/
dist/
dist-ssr/
build/
.next/
.nuxt/
.vite/
.cache/
coverage/
.pnp.*
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml
.yarn/unplugged

# Lockfiles que não estamos usando (manter apenas o do gerenciador escolhido)
# Descomente o que NÃO for usar:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

